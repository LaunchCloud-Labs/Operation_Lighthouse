#!/usr/bin/env ruby
require 'bundler/setup'
require 'thor'
require_relative '../lib/fleh_mesh'

class FlehMeshCLI < Thor
  def self.help(shell, subcommand = false)
    puts FlehMesh::UI::BANNER
    super
  end

  desc "setup_id DOMAIN TOKEN", "Configure a free DuckDNS identity (e.g. domain.duckdns.org)"
  def setup_id(domain, token)
    FlehMesh::Logic.setup_id(domain, token)
  end

  desc "punch", "Punch a hole in your router (UPnP) for Port 22"
  method_option :port, default: 54321, type: :numeric, aliases: '-p'
  def punch
    FlehMesh::Logic.punch(options[:port])
  end

  desc "install", "Install the CLI globally as lcl-tunnel and lcl-lighthouse"
  def install
    FlehMesh::Logic.install
  end

  desc "check", "Perform a local pre-flight check"
  def check
    FlehMesh::Logic.check
  end

  desc "status IP", "Show mesh health and tunnel status"
  method_option :port, default: 2222, type: :numeric, aliases: '-p'
  def status(ip)
    FlehMesh::Logic.status(ip, options[:port])
  end

  desc "audit IP", "Perform a security audit of the Lighthouse VPS"
  method_option :user, default: 'root', aliases: '-u'
  def audit(ip)
    FlehMesh::Logic.audit(ip, options[:user])
  end

  desc "init_lighthouse IP", "Provisions a new Lighthouse VPS at the given IP"
  method_option :user, default: 'root', aliases: '-u'
  def init_lighthouse(ip)
    FlehMesh::Logic.init_lighthouse(ip, options[:user])
  end

  desc "connect_home LIGHTHOUSE_IP", "Establishes a persistent reverse tunnel to the Lighthouse"
  method_option :lighthouse_user, default: 'lighthouse', aliases: '-u'
  method_option :remote_port, default: 2222, type: :numeric, aliases: '-p'
  def connect_home(lighthouse_ip)
    FlehMesh::Logic.connect_home(lighthouse_ip, options[:lighthouse_user], options[:remote_port])
  end

  desc "add_user NAME", "Adds a new employee to the mesh"
  def add_user(name)
    FlehMesh::Logic.add_user(name)
  end
end

FlehMeshCLI.start(ARGV)
